# Variables consumed by docker-compose.yml. Copy to .env at the repo root.

# Postgres (in-compose database) — set a strong POSTGRES_PASSWORD before any non-local deploy
POSTGRES_USER=veritrust
POSTGRES_PASSWORD=change-me
POSTGRES_DB=veritrust

# Redis (in-compose broker) — set a strong REDIS_PASSWORD before any non-local deploy
REDIS_PASSWORD=

# Clerk (from your Clerk dashboard)
CLERK_JWKS_URL=
CLERK_ISSUER=
CLERK_AUDIENCE=
CLERK_SECRET_KEY=
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=

# Production reverse proxy (only used by docker-compose.prod.yml; leave blank for local)
APP_DOMAIN=
API_DOMAIN=
ACME_EMAIL=
